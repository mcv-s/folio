{
  "manifest_version": 3,
  "name": "Folio - Ultimate New Tab",
  "version": "1.0",
  "description": "A custom new tab. Supports custom CSS, widgets + integrations, random & custom background images, and an AI search bar.",

  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },

  "permissions": ["storage", "contextMenus", "activeTab", "history", "tabs"],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },

  "background": {
  "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/Folio-Icon-A-Stylistic.png",
      "24": "icons/Folio-Icon-A-Stylistic.png",
      "32": "icons/Folio-Icon-A-Stylistic.png",
      "48": "icons/Folio-Icon-A-Stylistic.png"
    },

    "theme_icons": [
      {
        "light": "icons/Folio-Icon-Light.png",
        "dark": "icons/Folio-Icon-Dark.png",
        "size": 16
      },
      {
        "light": "icons/Folio-Icon-Light.png",
        "dark": "icons/Folio-Icon-Dark.png",
        "size": 24
      },
      {
        "light": "icons/Folio-Icon-Light.png",
        "dark": "icons/Folio-Icon-Dark.png",
        "size": 32
      },
      {
        "light": "icons/Folio-Icon-Light.png",
        "dark": "icons/Folio-Icon-Dark.png",
        "size": 48
      }
    ],

    "default_popup": "popup.html"
  },
  "icons": {
  "16": "icons/Folio-Icon-Main.png",
  "48": "icons/Folio-Icon-Main.png",
  "128": "icons/Folio-Icon-Main.png"
  }
}